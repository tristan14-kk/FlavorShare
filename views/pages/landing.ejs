<%- include('../partials/header') %>

<div class="landing-page">
  <nav class="landing-nav">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <img src="/images/logo.png" alt="FlavorShare" class="logo-img">
      </a>
      <div class="nav-links">
        <a href="/login" class="btn btn-outline">Login</a>
        <a href="/signup" class="btn btn-primary">Get Started</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <h1>Share Your <span class="highlight">Culinary Journey</span></h1>
      <p>Join thousands of food enthusiasts sharing their favorite recipes. Discover new dishes, connect with home cooks, and build your recipe collection.</p>
      <a href="/signup" class="btn btn-primary btn-large">Start Sharing Today</a>
    </div>
    <div class="hero-image">
      <img src="/images/logolanding.png" alt="FlavorShare" class="hero-logo-img">
    </div>
  </section>

  <section class="features">
    <h2>Why FlavorShare?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <span class="feature-icon">📝</span>
        <h3>Create & Share</h3>
        <p>Easily upload your recipes with photos, ingredients, and step-by-step instructions.</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🔍</span>
        <h3>Discover</h3>
        <p>Browse recipes by category and find inspiration for your next meal.</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">👥</span>
        <h3>Connect</h3>
        <p>Follow your favorite home cooks and build a community around food.</p>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🔒</span>
        <h3>Secure</h3>
        <p>Your data is protected with industry-standard security measures.</p>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Ready to Share Your Recipes?</h2>
    <p>Join FlavorShare today and become part of our growing community of food lovers.</p>
    <a href="/signup" class="btn btn-primary btn-large">Create Free Account</a>
  </section>
</div>

<%- include('../partials/footer') %>
