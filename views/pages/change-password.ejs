<%- include('../partials/header') %>

<div class="form-page">
  <div class="form-container form-container-narrow">
    <h1>Change Password</h1>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="alert <%= errors[0].type === 'success' ? 'alert-success' : 'alert-error' %>">
        <% errors.forEach(error => { %>
          <p><%= error.msg %></p>
        <% }) %>
      </div>
    <% } %>

    <form action="/profile/change-password?_method=PUT" method="POST" class="password-form">
      <% if (typeof canSetPassword !== 'undefined' && canSetPassword) { %>
        <div class="alert alert-info">
          <p>You signed up with Google. Set a password to also enable email/password login.</p>
        </div>
      <% } else { %>
        <div class="form-group">
          <label for="currentPassword">Current Password</label>
          <input type="password" id="currentPassword" name="currentPassword" required>
        </div>
      <% } %>

      <div class="form-group">
        <label for="newPassword">New Password</label>
        <input type="password" id="newPassword" name="newPassword" required minlength="6">
        <small>Must be at least 6 characters with at least one number</small>
      </div>

      <div class="form-group">
        <label for="confirmNewPassword">Confirm New Password</label>
        <input type="password" id="confirmNewPassword" name="confirmNewPassword" required>
      </div>

      <div class="form-actions">
        <a href="/profile/edit" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary"><%= typeof canSetPassword !== 'undefined' && canSetPassword ? 'Set Password' : 'Change Password' %></button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
