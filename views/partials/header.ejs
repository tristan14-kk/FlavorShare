<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="FlavorShare - Share your culinary journey with food lovers around the world">
  <title><%= typeof title !== 'undefined' ? title : 'FlavorShare' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/home" class="nav-logo">
        <img src="/images/logo.png" alt="FlavorShare" class="logo-img">
      </a>
      
      <div class="nav-links">
        <a href="/home" class="nav-link">Home</a>
        <a href="/recipes/new" class="nav-link">Create Recipe</a>
        <a href="/profile" class="nav-link">My Profile</a>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <span class="admin-badge">Admin</span>
        <% } %>
      </div>

      <div class="nav-user">
        <a href="/profile" class="user-avatar">
          <% if (user && user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="<%= user.fullName %>" class="avatar-img">
          <% } else { %>
            <span class="avatar-initials"><%= user ? user.initials : '?' %></span>
          <% } %>
        </a>
        <form action="/logout" method="POST" class="logout-form">
          <button type="button" class="btn-logout" onclick="document.getElementById('logoutModal').style.display='flex'">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <!-- Logout Modal -->
<div id="logoutModal" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('logoutModal').style.display='none'">×</button>
    <h2>Are you sure you want to log out of <span class="highlight">FlavorShare</span>?</h2>
    <p>Your delicious recipes will be waiting for you when you return!</p>
    <div class="modal-actions">
      <button class="btn btn-outline btn-full" onclick="document.getElementById('logoutModal').style.display='none'">Stay Logged In</button>
      <form action="/logout" method="POST" style="width:100%">
        <button type="submit" class="btn btn-primary btn-full">Yes, Log Out</button>
      </form>
    </div>
  </div>
</div>
  <% } %>
  <main class="main-content">
